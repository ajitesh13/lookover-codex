POSTGRES_DB=lookover_codex
POSTGRES_USER=lookover
POSTGRES_PASSWORD=lookover
DATABASE_URL=postgres://lookover:lookover@postgres:5432/lookover_codex?sslmode=disable
API_PORT=8080
REPORTS_DIR=/app/reports
CONTROLS_DIR=/app/controls
# Optional demo auth fallback used by the seeded backend session flow.
SEED_REVIEWER_EMAIL=reviewer@lookover.local
SEED_REVIEWER_PASSWORD=demo-reviewer
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_LOOKOVER_API_BASE_URL=http://localhost:8080
LOOKOVER_API_BASE_URL=http://localhost:8080
# Override the host port when 3000 is already taken locally.
WEB_PORT=3000
